# Copy to `backend/.env` and adjust.
#
# ── Local (runserver on your machine, Postgres on localhost) ───────────────
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
# DEBUG=True adds hostnames with ports (e.g. localhost:5173) for the Vite dev proxy.

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,http://127.0.0.1:5174
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,http://127.0.0.1:5174

DB_NAME=raffaello
DB_USER=postgres
DB_PASSWORD=test
DB_HOST=127.0.0.1
DB_PORT=5432

# ── Production (Docker Compose on server; DB_HOST must be `db`) ─────────────
# SECRET_KEY=<generate-a-new-long-random-string>
# DEBUG=False
# ALLOWED_HOSTS=raffaello.se,www.raffaello.se
# CORS_ALLOWED_ORIGINS=https://raffaello.se,https://www.raffaello.se
# CSRF_TRUSTED_ORIGINS=https://raffaello.se,https://www.raffaello.se
#
# DB_NAME=raffaello
# DB_USER=raffaello_user
# DB_PASSWORD=<same-as-POSTGRES_PASSWORD in root .env.db>
# DB_HOST=db
# DB_PORT=5432
#
# After HTTPS works end-to-end, enable HSTS (seconds; e.g. one year):
# SECURE_HSTS_SECONDS=31536000
# SECURE_HSTS_INCLUDE_SUBDOMAINS=True
# SECURE_HSTS_PRELOAD=False
